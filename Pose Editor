	entryCopyBtn.Size = UDim2.new(0, 56, 0, 18)
	entryCopyBtn.Position = UDim2.new(1, -80, 0, 1)
	entryCopyBtn.BackgroundColor3 = THEME.ButtonIdle
	entryCopyBtn.AutoButtonColor = false
	entryCopyBtn.Text = ""
	entryCopyBtn.Parent = cardHeader
	addCorner(entryCopyBtn, 5)

	local entryCopyLayout = Instance.new("UIListLayout")
	entryCopyLayout.FillDirection = Enum.FillDirection.Horizontal
	entryCopyLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	entryCopyLayout.VerticalAlignment = Enum.VerticalAlignment.Center
	entryCopyLayout.Padding = UDim.new(0, 3)
	entryCopyLayout.Parent = entryCopyBtn

	local entryCopyIconHolder = Instance.new("Frame")
	entryCopyIconHolder.Size = UDim2.new(0, 11, 0, 11)
	entryCopyIconHolder.BackgroundTransparency = 1
	entryCopyIconHolder.LayoutOrder = 1
	entryCopyIconHolder.Parent = entryCopyBtn
	iconCopy(entryCopyIconHolder, THEME.Accent)

	local entryCopyLabel = Instance.new("TextLabel")
	entryCopyLabel.Size = UDim2.new(0, 34, 1, 0)
	entryCopyLabel.BackgroundTransparency = 1
	entryCopyLabel.Font = Enum.Font.GothamBold
	entryCopyLabel.TextSize = 9
	entryCopyLabel.TextColor3 = THEME.TextMain
	entryCopyLabel.Text = dict.Copy
	entryCopyLabel.LayoutOrder = 2
	entryCopyLabel.Parent = entryCopyBtn

	setupButtonFX(entryCopyBtn, THEME.ButtonIdle)

	-- Nội dung code của lần lưu này
	local cardText = Instance.new("TextLabel")
	cardText.Size = UDim2.new(1, 0, 0, 0)
	cardText.AutomaticSize = Enum.AutomaticSize.Y
	cardText.BackgroundTransparency = 1
	cardText.TextXAlignment = Enum.TextXAlignment.Left
	cardText.TextYAlignment = Enum.TextYAlignment.Top
	cardText.Font = Enum.Font.Code
	cardText.TextSize = 10
	cardText.TextColor3 = Color3.fromRGB(150, 230, 200)
	cardText.TextWrapped = true
	cardText.Text = resultText
	cardText.LayoutOrder = 2
	cardText.Parent = card

	local entry = {card = card, text = resultText, copyLabel = entryCopyLabel}
	table.insert(outputEntries, entry)
	refreshEmptyLabelVisibility()

	entryCopyBtn.MouseButton1Click:Connect(function()
		popEffect(entryCopyBtn)
		if setclipboard then
			setclipboard(entry.text)
			entryCopyLabel.Text = dict.Copied
		else
			entryCopyLabel.Text = dict.NotSupported
		end
		task.delay(1, function() entryCopyLabel.Text = dict.Copy end)
	end)

	entryDeleteBtn.MouseButton1Click:Connect(function()
		popEffect(entryDeleteBtn)
		-- Xóa entry này khỏi danh sách logic ngay (để Copy All không còn tính nó)
		for i, e in ipairs(outputEntries) do
			if e == entry then
				table.remove(outputEntries, i)
				break
			end
		end
		refreshEmptyLabelVisibility()
		-- Hiệu ứng mờ dần rồi mới xóa card khỏi UI, mượt hơn so với biến mất ngay
		tween(card, {BackgroundTransparency = 1}, 0.15):Play()
		for _, d in ipairs(card:GetDescendants()) do
			if d:IsA("TextLabel") or d:IsA("TextButton") then
				tween(d, {TextTransparency = 1, BackgroundTransparency = 1}, 0.15):Play()
			elseif d:IsA("Frame") then
				tween(d, {BackgroundTransparency = 1}, 0.15):Play()
			elseif d:IsA("UIStroke") then
				tween(d, {Transparency = 1}, 0.15):Play()
			end
		end
		task.delay(0.16, function()
			card:Destroy()
		end)
	end)

	return entry
end

local function clearAllOutputEntries()
	for _, entry in ipairs(outputEntries) do
		entry.card:Destroy()
	end
	outputEntries = {}
	refreshEmptyLabelVisibility()
end

