	cardLayout.Padding = UDim.new(0, 4)
	cardLayout.Parent = card

	-- Hàng tiêu đề nhỏ: số thứ tự lần lưu + nút Copy riêng cho entry này
	local cardHeader = Instance.new("Frame")
	cardHeader.Size = UDim2.new(1, 0, 0, 20)
