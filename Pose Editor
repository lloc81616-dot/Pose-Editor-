	for _, line in ipairs(fullEntries) do table.insert(finalLines, line) end
	table.insert(finalLines, "}")

	local resultText = table.concat(finalLines, "\n")
	-- Thêm 1 entry MỚI vào danh sách, KHÔNG ghi đè/xóa các lần lưu trước đó (đây là fix cho lỗi bị mất dữ liệu)
	addOutputEntry(resultText, dict)
	task.defer(function()
		-- đợi 1 frame để UIListLayout/AutomaticCanvasSize cập nhật xong rồi mới cuộn xuống cuối
		outScroll.CanvasPosition = Vector2.new(0, math.max(outScroll.AbsoluteCanvasSize.Y - outScroll.AbsoluteWindowSize.Y, 0))
	end)
	print(resultText)

	local original = saveBtn.Text
	saveBtn.Text = dict.ExportSuccess
	task.delay(0.8, function() saveBtn.Text = original end)
end)

