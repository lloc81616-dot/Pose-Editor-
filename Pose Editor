local function generateCFrameString(cf)
	local px, py, pz = cf.Position.X, cf.Position.Y, cf.Position.Z
	local rx, ry, rz = cf:ToEulerAnglesXYZ()
	return string.format("CFrame.new(%.4f, %.4f, %.4f) * CFrame.Angles(%.5f, %.5f, %.5f)", px, py, pz, rx, ry, rz)
end

