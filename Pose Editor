--// ===== LOGIC CHUYỂN ĐỔI RIG (GLOBAL — gọi từ selectNewDummy phía trên) =====
function switchRig(newRig)
	if newRig == currentRig then return end
	currentRig = newRig
	names = RIG[currentRig].joints
	selected = names[1]
	selectedLabel.Text = selected

	local targetPos = (newRig == "R6") and UDim2.new(0, 0, 0, 0) or UDim2.new(0.5, 0, 0, 0)
	tween(rigSlider, {Position = targetPos}, 0.2):Play()
	tweenColor(r6Tab, "TextColor3", (newRig == "R6") and Color3.new(1, 1, 1) or THEME.TextDim, 0.15)
	tweenColor(r15Tab, "TextColor3", (newRig == "R15") and Color3.new(1, 1, 1) or THEME.TextDim, 0.15)

	for _, b in pairs(jointButtons) do tween(b, {BackgroundTransparency = 1}, 0.08):Play() end

	task.delay(0.1, function()
		buildJointButtons()
		for jointName, btn in pairs(jointButtons) do
			local motor = getMotor(jointName)
			if motor and dirtyMotors[motor] then
				btn:SetAttribute("Dirty", true)
				if jointName ~= selected then btn.BackgroundColor3 = Color3.fromRGB(72, 52, 20) end
			end
		end
		for _, b in pairs(jointButtons) do
			b.BackgroundTransparency = 1
			tween(b, {BackgroundTransparency = 0}, 0.15):Play()
		end
	end)
	popEffect(selectedLabel)
end

r6Tab.MouseButton1Click:Connect(function() switchRig("R6") end)
r15Tab.MouseButton1Click:Connect(function() switchRig("R15") end)

