-- Gắn hiệu ứng hover (phóng to nhẹ + sáng màu + glow viền đậm) + âm thanh hover/click cho MỌI nút
-- dùng chung 1 hàm, để không phải sửa tay từng nút rời rạc trong file (dễ sót, dễ lỗi).
-- baseColor: màu nền gốc của nút (dùng để biết màu "sáng hơn" cần tween về)
-- hoverColor: (tùy chọn) màu khi hover; nếu không truyền, tự tính sáng hơn baseColor một chút
local function setupButtonFX(button, baseColor, hoverColor)
	if not baseColor then baseColor = button.BackgroundColor3 end
	if not hoverColor then
		local h, s, v = baseColor:ToHSV()
		hoverColor = Color3.fromHSV(h, s, math.min(v + 0.18, 1))
	end

	local originalSize = button.Size
	local hoverSize = UDim2.new(
		originalSize.X.Scale, originalSize.X.Offset + 3,
		originalSize.Y.Scale, originalSize.Y.Offset + 2
	)

	-- Glow viền đậm khi hover: 1 UIStroke riêng, trong suốt lúc thường, hiện đậm lên khi rê chuột
	local glow = Instance.new("UIStroke")
	glow.Color = THEME.Accent
	glow.Thickness = 2
	glow.Transparency = 1
	glow.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	glow.Parent = button

	button.MouseEnter:Connect(function()
		playHoverSound()
		tween(button, {BackgroundColor3 = hoverColor, Size = hoverSize}, 0.1):Play()
		tween(glow, {Transparency = 0.25}, 0.12):Play()
	end)

	button.MouseLeave:Connect(function()
		tween(button, {BackgroundColor3 = baseColor, Size = originalSize}, 0.12):Play()
		tween(glow, {Transparency = 1}, 0.15):Play()
	end)

	button.MouseButton1Click:Connect(function()
		playClickSound()
	end)
end

-- Biến thể cho các tab nền trong suốt (R6/R15, VI/EN): không đổi màu nền (vì không có màu),
-- chỉ phóng to nhẹ + âm thanh, để không phá vỡ hiệu ứng slider màu phía sau.
local function setupTabFX(button)
	local originalSize = button.Size
	local hoverSize = UDim2.new(
		originalSize.X.Scale, originalSize.X.Offset,
		originalSize.Y.Scale, originalSize.Y.Offset - 2
	)

	button.MouseEnter:Connect(function()
		playHoverSound()
		tween(button, {Size = hoverSize}, 0.1):Play()
	end)

	button.MouseLeave:Connect(function()
		tween(button, {Size = originalSize}, 0.12):Play()
	end)

	button.MouseButton1Click:Connect(function()
		playClickSound()
	end)
end

-- ===== SHIMMER: ánh sáng chéo lướt qua nút theo chu kỳ (giống hiệu ứng "shiny" trên nút loot box) =====
-- Tạo 1 dải sáng mỏng nghiêng, dùng UIGradient để vẽ dải sáng, rồi tween Position của 1 Frame chứa nó
-- chạy từ ngoài-trái sang ngoài-phải nút, lặp lại sau một khoảng nghỉ ngẫu nhiên để không "đều" và rô-bốt quá.
local function addShimmer(button, periodSeconds)
	periodSeconds = periodSeconds or 3.2

	local clip = Instance.new("Frame")
	clip.Name = "ShimmerClip"
	clip.Size = UDim2.new(1, 0, 1, 0)
	clip.BackgroundTransparency = 1
	clip.ClipsDescendants = true
	clip.ZIndex = button.ZIndex + 1
	clip.Parent = button
	-- tự bo góc theo nút để dải sáng không tràn ra ngoài hình bo góc
	local corner = button:FindFirstChildOfClass("UICorner")
	if corner then
		local c2 = Instance.new("UICorner")
		c2.CornerRadius = corner.CornerRadius
		c2.Parent = clip
	end

	local shimmerBar = Instance.new("Frame")
	shimmerBar.Name = "ShimmerBar"
	shimmerBar.Size = UDim2.new(0, 24, 2, 0)
	shimmerBar.Position = UDim2.new(-0.4, 0, -0.5, 0)
	shimmerBar.Rotation = 18
	shimmerBar.BackgroundColor3 = Color3.new(1, 1, 1)
	shimmerBar.BorderSizePixel = 0
	shimmerBar.ZIndex = clip.ZIndex
	shimmerBar.Parent = clip

	local grad = Instance.new("UIGradient")
	grad.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 1),
		NumberSequenceKeypoint.new(0.5, 0.55),
		NumberSequenceKeypoint.new(1, 1),
	})
	grad.Parent = shimmerBar

	task.spawn(function()
		while button.Parent do
			local t = tween(shimmerBar, {Position = UDim2.new(1.4, 0, -0.5, 0)}, 0.7, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
			t:Play()
			t.Completed:Wait()
			shimmerBar.Position = UDim2.new(-0.4, 0, -0.5, 0)
			task.wait(periodSeconds + math.random() * 1.5) -- nghỉ ngẫu nhiên để tự nhiên hơn
		end
	end)
end

-- ===== PULSE: nhịp đập nhẹ liên tục, dùng cho nút quan trọng (Save) để thu hút chú ý =====
local function addPulse(button)
	local baseScale = button.Size
	local pulseScale = UDim2.new(
		baseScale.X.Scale, baseScale.X.Offset + 2,
		baseScale.Y.Scale, baseScale.Y.Offset + 1
	)
	local glowPulse = Instance.new("UIStroke")
	glowPulse.Color = THEME.Success
	glowPulse.Thickness = 1.5
	glowPulse.Transparency = 0.6
	glowPulse.Parent = button

	task.spawn(function()
		while button.Parent do
			tween(button, {Size = pulseScale}, 1.0, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut):Play()
			tween(glowPulse, {Transparency = 0.15}, 1.0, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut):Play()
			task.wait(1.0)
			tween(button, {Size = baseScale}, 1.0, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut):Play()
			tween(glowPulse, {Transparency = 0.6}, 1.0, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut):Play()
			task.wait(1.0)
		end
	end)
end

--// ===== ICON VECTOR (Frame/UIGradient/UICorner) — THAY EMOJI =====
-- Mỗi icon là 1 Frame nhỏ chứa các hình khối đơn giản, luôn hiển thị đúng, không phụ thuộc asset ngoài.
local function makeIconHolder(parent, size)
	local holder = Instance.new("Frame")
	holder.Size = size or UDim2.new(0, 16, 0, 16)
	holder.BackgroundTransparency = 1
	holder.Parent = parent
	return holder
end

-- Icon xương (bone) — 2 chấm tròn nối bằng 1 thanh chéo, dùng cho nút bật/tắt chính
