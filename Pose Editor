--// ===== TRA CỨU MOTOR THEO RIG =====
getMotor = function(jointName)
	if not currentDummy or not currentDummy.Parent then return nil end
	if currentRig == "R6" then
		local container = currentDummy:FindFirstChild(RIG.R6.container)
		local motor = container and container:FindFirstChild(jointName)
		if motor and motor:IsA("Motor6D") then return motor end
		return currentDummy:FindFirstChild(jointName, true)
	else
		local ownerPartName = RIG.R15.jointOwners[jointName]
		local part = ownerPartName and currentDummy:FindFirstChild(ownerPartName)
		if part then
			for _, child in ipairs(part:GetChildren()) do
				if child:IsA("Motor6D") then return child end
			end
		end
		return currentDummy:FindFirstChild(jointName, true)
	end
end

