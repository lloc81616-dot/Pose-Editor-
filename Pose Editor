--// ===== LOGIC KÉO TRÊN TOUCHPAD =====
local padDragging = false
local padDragStartPos = nil
local padDragStartC0 = nil
local padDragMotor = nil

local PIXELS_PER_STUD = 12
local PIXELS_PER_DEGREE = 2.5

local function applyTouchpadDelta(deltaPixels)
	if not padDragMotor or not padDragStartC0 then return end

	if gizmoMode == "Move" then
		local amount = deltaPixels.X / PIXELS_PER_STUD
		local offset = Vector3.new(0, 0, 0)
		if gizmoAxis == "X" then offset = Vector3.new(amount, 0, 0)
		elseif gizmoAxis == "Y" then offset = Vector3.new(0, amount, 0)
		else offset = Vector3.new(0, 0, amount) end
		padDragMotor.C0 = padDragStartC0 * CFrame.new(offset)
	else
		local amountDeg = deltaPixels.X / PIXELS_PER_DEGREE
		local rad = math.rad(amountDeg)
		local rx, ry, rz = 0, 0, 0
		if gizmoAxis == "X" then rx = rad
		elseif gizmoAxis == "Y" then ry = rad
		else rz = rad end
		padDragMotor.C0 = padDragStartC0 * CFrame.Angles(rx, ry, rz)
	end
end

local function beginPadDrag(screenPos)
	local motor = getMotor(selected)
	if not motor then return end
	padDragging = true
	padDragMotor = motor
	padDragStartC0 = motor.C0
	padDragStartPos = screenPos
	tween(touchpadCenterDot, {BackgroundColor3 = THEME.Dirty}, 0.1):Play()
end

local function endPadDrag()
	if padDragging and padDragMotor then
		markDirty(selected, padDragMotor)
	end
	padDragging = false
	padDragMotor = nil
	padDragStartC0 = nil
	padDragStartPos = nil
	tween(touchpadCenterDot, {BackgroundColor3 = THEME.Accent}, 0.1):Play()
end

touchpad.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		beginPadDrag(Vector2.new(input.Position.X, input.Position.Y))
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if not padDragging then return end
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		local currentPos = Vector2.new(input.Position.X, input.Position.Y)
		applyTouchpadDelta(currentPos - padDragStartPos)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		if padDragging then endPadDrag() end
	end
end)

local function selectNewDummy(model)
	currentDummy = model
	dummyTargetLabel.Text = string.format(LANG_DATA[currentLang].ActiveDummy, model.Name)
	dummyTargetLabel.BackgroundColor3 = Color3.fromRGB(22, 46, 32)
	dummyTargetLabel.TextColor3 = THEME.Success
	popEffect(dummyTargetLabel)

	dirtyMotors = {}
	originalC0 = {}

	for _, m in ipairs(currentDummy:GetDescendants()) do
		if m:IsA("Motor6D") then
			originalC0[m.Name] = m.C0
		end
	end

	local looksLikeR15 = currentDummy:FindFirstChild("UpperTorso") ~= nil
	local targetRig = looksLikeR15 and "R15" or "R6"
	if targetRig ~= currentRig then
		switchRig(targetRig)
	end

	selectJoint(names[1])
	buildJointButtons()
	refreshDirtyCount()
end

local camera = Workspace.CurrentCamera
UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		local ray = camera:ViewportPointToRay(input.Position.X, input.Position.Y)
		local raycastResult = Workspace:Raycast(ray.Origin, ray.Direction * 500)

		if raycastResult and raycastResult.Instance then
			local hit = raycastResult.Instance
			local model = hit:FindFirstAncestorOfClass("Model")
			if model and model:FindFirstChildOfClass("Humanoid") then
				selectNewDummy(model)
			end
		end
	end
end)

local function rotateByButton(axisX, axisY, axisZ)
	if not currentDummy then return end
	local motor = getMotor(selected)
	if not motor then return end
	motor.C0 = motor.C0 * CFrame.Angles(math.rad(axisX * step), math.rad(axisY * step), math.rad(axisZ * step))
	markDirty(selected, motor)
end

local function moveByButton(moveX, moveY, moveZ)
	if not currentDummy then return end
	local motor = getMotor(selected)
	if not motor then return end
	local factor = step / 20
	motor.C0 = motor.C0 * CFrame.new(moveX * factor, moveY * factor, moveZ * factor)
	markDirty(selected, motor)
end

