local function setJointButtonState(name)
	for n, b in pairs(jointButtons) do
		if n == name then
			tweenColor(b, "BackgroundColor3", THEME.ButtonActive, 0.1)
		elseif b:GetAttribute("Dirty") then
			tweenColor(b, "BackgroundColor3", Color3.fromRGB(72, 52, 20), 0.1)
		else
			tweenColor(b, "BackgroundColor3", THEME.ButtonIdle, 0.1)
		end
