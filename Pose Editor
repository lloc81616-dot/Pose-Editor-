local function refreshDirtyCount()
	local count = 0
	for _ in pairs(dirtyMotors) do count += 1 end
	if currentLang == "VI" then
		dirtyCountLabel.Text = count .. " đã sửa"
	else
		dirtyCountLabel.Text = count .. " modified"
	end
	dirtyCountLabel.TextColor3 = (count > 0) and THEME.Dirty or THEME.TextDim
